# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
BASE_URL=https://your-domain.com           # Public URL of this backend (no trailing slash)
FRONTEND_URL=https://your-domain.com       # Where index.html is served from

# ─── SQLite ───────────────────────────────────────────────────────────────────
DB_PATH=./data/designs.db                  # Path to SQLite database file

# ─── Download tokens ──────────────────────────────────────────────────────────
DOWNLOAD_TOKEN_EXPIRES_HOURS=72            # How long download links stay valid (default 72h)

# ─── WooCommerce ──────────────────────────────────────────────────────────────
# Leave blank to skip WooCommerce and use the placeholder checkout flow
WC_URL=https://your-store.com             # WordPress/WooCommerce site URL (no trailing slash)
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxx   # WooCommerce → Settings → Advanced → REST API
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxx
WC_API_VERSION=v3                          # WooCommerce REST API version (default: v3)
WC_PRODUCT_ID=123                          # Product ID of the "Bespoke Design Files" product
WC_PRODUCT_PRICE=49.00                    # Price shown in order (must match WooCommerce product)
WC_WEBHOOK_SECRET=your-webhook-secret     # WooCommerce → Settings → Advanced → Webhooks → Secret

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Works with any SMTP provider (Gmail, Mailgun, SendGrid, etc.)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false                          # true for port 465
SMTP_USER=postmaster@mg.your-domain.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="Creature Cycles <hello@your-domain.com>"
EMAIL_REPLY_TO=hello@your-domain.com

# ─── Admin panel ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-to-a-strong-password  # Protects /admin and /api/admin/*

# ─── Design review lead time ──────────────────────────────────────────────────
REVIEW_LEAD_TIME_DAYS=7                    # Shown to customer in payment confirmation email
